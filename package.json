{
  "name": "@igorjs/pure-test",
  "version": "0.1.0",
  "description": "Minimal cross-runtime test runner. Works on Node, Deno, Bun, Workers, and Browser. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pure-test": "./bin/pure-test.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "tsgo --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "build": "node scripts/build.mjs",
    "test": "node tests/self-test.mjs",
    "test:types": "tsgo -p tsconfig.test.json",
    "test:ci": "node scripts/test-ci.mjs",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "node scripts/prepublish.mjs"
  },
  "keywords": [
    "test",
    "testing",
    "test-runner",
    "cross-runtime",
    "deno",
    "bun",
    "node",
    "tap",
    "zero-dependencies"
  ],
  "author": "igorjs <oss@mail.igorjs.io>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/igorjs/pure-test#readme",
  "bugs": {
    "url": "https://github.com/igorjs/pure-test/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igorjs/pure-test.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/igorjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@typescript/native-preview": "7.0.0-dev.20260503.1"
  },
  "peerDependencies": {
    "typescript": ">=5.7.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
