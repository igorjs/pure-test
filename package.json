{
  "name": "@igorjs/pure-test",
  "version": "0.4.1",
  "description": "Minimal cross-runtime test runner. Works on Node, Deno, Bun, Workers, and Browser. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./deno": {
      "types": "./dist/deno.d.ts",
      "import": "./dist/deno.js"
    }
  },
  "bin": {
    "pure-test": "bin/pure-test.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "tsgo --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "build": "node scripts/build.mjs",
    "test": "node tests/self-test.mjs",
    "test:types": "tsgo -p tsconfig.test.json",
    "test:ci": "node scripts/test-ci.mjs",
    "coverage": "c8 --config .c8rc.node.json node tests/self-test.mjs",
    "coverage:node": "c8 --config .c8rc.node.json --report-dir=coverage/node --reporter=text --reporter=lcov --reporter=html node tests/self-test.mjs",
    "coverage:deno": "rm -rf coverage/deno-raw coverage/deno && mkdir -p coverage/deno && deno run --allow-all --coverage=coverage/deno-raw tests/self-test.mjs && deno coverage --include=dist/ --exclude=dist/runtime/env-process.js --exclude=dist/runtime/exit-process.js coverage/deno-raw && deno coverage --include=dist/ --exclude=dist/runtime/env-process.js --exclude=dist/runtime/exit-process.js --lcov --output=coverage/deno/coverage.lcov coverage/deno-raw",
    "coverage:all": "node scripts/coverage-all.mjs",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "node scripts/prepublish.mjs"
  },
  "keywords": [
    "test",
    "testing",
    "test-runner",
    "cross-runtime",
    "deno",
    "bun",
    "node",
    "tap",
    "zero-dependencies"
  ],
  "author": "igorjs <oss@mail.igorjs.io>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/igorjs/pure-test#readme",
  "bugs": {
    "url": "https://github.com/igorjs/pure-test/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/igorjs/pure-test.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/igorjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@typescript/native-preview": "7.0.0-dev.20260503.1",
    "c8": "11.0.0",
    "miniflare": "4.20260504.0",
    "playwright": "1.59.1"
  },
  "peerDependencies": {
    "typescript": ">=5.7.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
