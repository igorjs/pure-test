# Pure Test pnpm/npm policy — keep dependencies pinned and Node engine strict.
#
# save-exact=true   : `pnpm add <pkg>` writes 1.2.3 (no ^/~ prefix). Matches
#                     the existing devDependencies, prevents accidental
#                     range-prefixed additions.
# engine-strict=true: refuse install if the user's Node is outside engines.node.
#                     Catches version drift at install time, not at runtime.
save-exact=true
engine-strict=true
